    "@angular/router": "22.0.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "open-props": "1.7.16",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "20.3.8",
    "@angular/compiler-cli": "20.3.9",
    "@types/jasmine": "5.1.12",
