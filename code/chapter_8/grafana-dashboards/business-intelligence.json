{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Chapter 8 Business Intelligence dashboard. Three rows: Business Health (revenue, conversion, error budget), SLI Status (Availability/Latency/Correctness + budget burn), Investigation (failures, latency vs conversion).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Row 1 — Business Health",
      "type": "row"
    },
    {
      "type": "stat",
      "title": "Revenue Rate ($/hour)",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2500 },
              { "color": "green", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(orders_total_amount_sum[5m])) * 3600",
          "legendFormat": "Revenue $/hour",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Checkout Conversion %",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 65 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * (sum(rate(checkout_funnel_completed_total[5m])) / clamp_min(sum(rate(checkout_funnel_started_total[5m])), 1e-12))",
          "legendFormat": "Conversion %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Availability Error Budget Remaining (30d)",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "description": "Percentage of the 99.9% availability error budget that is still unspent over the 30-day window.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.6 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "clamp_min(1 - (sum(increase(http_server_request_duration_seconds_count{job=\"orders\",http_route=\"/orders\",http_request_method=\"POST\",http_response_status_code=~\"5..\"}[30d])) / (0.001 * clamp_min(sum(increase(http_server_request_duration_seconds_count{job=\"orders\",http_route=\"/orders\",http_request_method=\"POST\"}[30d])), 1))), 0)",
          "legendFormat": "Budget remaining",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "panels": [],
      "title": "Row 2 — SLI Status",
      "type": "row"
    },
    {
      "type": "stat",
      "title": "Availability SLI (5m)",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background" },
      "targets": [
        {
          "expr": "1 - checkout:availability_error_ratio_5m",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Latency SLI (<2s, 5m)",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background" },
      "targets": [
        {
          "expr": "1 - checkout:latency_error_ratio_5m",
          "legendFormat": "Latency",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Correctness SLI (5m)",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.999 },
              { "color": "green", "value": 0.9999 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background" },
      "targets": [
        {
          "expr": "1 - checkout:correctness_error_ratio_5m",
          "legendFormat": "Correctness",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Burn Rate — Availability (1h vs 5m)",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "description": "Burn rate = observed_error_rate / (1 - SLO). Critical >14.4×, Urgent >6×.",
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "checkout:availability_error_ratio_1h / 0.001",
          "legendFormat": "1h burn rate",
          "refId": "A"
        },
        {
          "expr": "checkout:availability_error_ratio_5m / 0.001",
          "legendFormat": "5m burn rate",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "panels": [],
      "title": "Row 3 — Investigation",
      "type": "row"
    },
    {
      "type": "piechart",
      "title": "Checkout Failure Reasons (1h)",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (failure_reason) (increase(orders_checkout_failures_total[1h]))",
          "legendFormat": "{{failure_reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency vs Conversion (5m)",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 10, "x": 8, "y": 15 },
      "description": "p99 checkout latency overlaid with conversion rate.",
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Conversion %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99 checkout (s)" },
            "properties": [
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(orders_checkout_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 checkout (s)",
          "refId": "A"
        },
        {
          "expr": "100 * (sum(rate(checkout_funnel_completed_total[5m])) / clamp_min(sum(rate(checkout_funnel_started_total[5m])), 1e-12))",
          "legendFormat": "Conversion %",
          "refId": "B"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Stock Level by Category",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 15 },
      "description": "Aggregated available stock units per top-level product category. New in chapter 8 via the inventory.stock.level gauge with a `category` attribute.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum by (category) (inventory_stock_level_units)",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Revenue by Category (24h, Loki)",
      "id": 11,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "description": "Revenue dollars summed per product category over the last 24 hours, sourced from the new `order.category` log attribute on the Orders service `Order created successfully` log.",
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (order_category) (sum_over_time({service_name=\"orders\"} |= \"Order created successfully\" | json | unwrap order_total [24h]))",
          "legendFormat": "{{order_category}}",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Correctness Errors (price mismatch / double charge)",
      "id": 12,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "description": "Investigative panel: raw correctness-failure log lines from the Orders service over the dashboard time range.",
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=\"orders\"} |~ \"Price mismatch|double charge\"",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["chapter-8", "slo", "business"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
